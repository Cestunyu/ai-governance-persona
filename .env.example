# Copy this file to .env.local and fill values locally.
# Do not commit .env.local or any real token value.

# Local token used by scripts/export-remote-results.sh.
# This should match the deployed Vercel EXPORT_TOKEN value, but the local
# variable name stays REMOTE_DATABASE_TOKEN so agents do not need the platform
# secret name.
REMOTE_DATABASE_TOKEN=

# Set to true only when Turnstile verification is configured.
REQUIRE_TURNSTILE=false
TURNSTILE_SECRET_KEY=

# Vercel / Supabase production storage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_RESULTS_TABLE=quiz_results
EXPORT_TOKEN=

# Remote data is accessed through the deployed API endpoint.
REMOTE_DATABASE_URL=https://linenyu-site.vercel.app/api/export.csv
