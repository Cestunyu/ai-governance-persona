  "questions": [
    {
      "id": "R01",
      "dimension": "r",
      "diagnosis": "catastrophic",
      "facet": "严重风险诊断",
      "text": "未来更强 AI 最应该优先防范哪类风险？",
      "options": [
        [
          "1",
          "A",
          "风险可能被高估；近期 AI 问题不应被说成系统性危机。"
        ],
        [
          "2.33",
          "B",
          "现实社会伤害：AI 可能被用于监控、歧视或剥夺人的机会。"
        ],
        [
          "3.67",
          "C",
          "失控风险：前沿系统可能做出人类无法阻止的行为。"
        ],
        [
          "5",
          "D",
          "社会失去方向：AI 扩张太快，公共决策越来越跟不上。"
        ]
      ]
    },
    {
      "id": "R04",
      "dimension": "r",
      "diagnosis": "opportunity",
      "facet": "机会成本诊断",
      "text": "如果政府出于安全考虑，要求 AI 公司放慢新模型发布或接受更严格审批，你更接近哪种立场？",
      "options": [
        [
          "1",
          "A",
          "安全应放在第一位。越强大的系统，越不能急着推给所有人用。"
        ],
        [
          "2.33",
          "B",
          "这类限制容易把权力锁在少数大公司和政府手里，让外部的人更难检查和参与。"
        ],
        [
          "3.67",
          "C",
          "过度放慢发布会让本该帮助很多人的 AI 工具更晚到来。"
        ],
        [
          "5",
          "D",
          "更大的代价是智能发展变慢，也压缩未来文明的可能性。"
        ]
      ]
    },
    {
      "id": "L01",
      "dimension": "l",
      "facet": "劳动替代与收益分配",
      "text": "如果 AI 让许多工作更便宜、更自动化，甚至可能带来大规模失业，政策应该优先做什么？",
      "options": [
        [
          "1",
          "A",
          "先让 AI 用起来。即使一些工作会消失，更高生产率也会创造新的机会。"
        ],
        [
          "2.33",
          "B",
          "帮人换工作。重点不是挡住 AI，而是让受影响的人能转到新岗位。"
        ],
        [
          "3.67",
          "C",
          "多分一点收益。AI 带来的财富不应只流向公司和投资者，也应回到劳动者。"
        ],
        [
          "5",
          "D",
          "先限制替代。会大规模取代人的 AI，不应该在没有保护措施时快速部署。"
        ]
      ]
    },
    {
      "id": "I01",
      "dimension": "i",
      "facet": "信息生态与合成内容",
      "text": "面对 AI 生成的假视频或仿冒内容快速传播，你更接近哪种判断？",
      "options": [
        [
          "1",
          "A",
